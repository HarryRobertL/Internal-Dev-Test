# Copy to .env in this directory. Never commit real secrets.

# SQLite (default for local demo)
DATABASE_URL=sqlite:///./customer_info.db

# PostgreSQL (recommended for production-shaped dev)
# DATABASE_URL=postgresql+psycopg://app_user:change_me@localhost:5432/customer_info

# Comma-separated origins for the React dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# development | test | production
APP_ENV=development

# After changing DATABASE_URL, run from backend/: alembic upgrade head
